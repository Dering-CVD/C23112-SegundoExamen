@model IEnumerable<SistemaAlquilerPlaya.UI.Models.ArticuloViewModel>

<h2>Artículos</h2>

<p>
    <a asp-action="Crear" class="btn btn-primary">
        Nuevo Artículo
    </a>
</p>

<table class="table table-striped">

    <thead>

        <tr>

            <th>Nombre</th>

            <th>Tipo</th>

            <th>Estado</th>

            <th>Precio por hora</th>

            <th></th>

        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Nombre</td>

                <td>@item.Tipo</td>

                <td>

                    @(item.Estado == 1
                    ? "Disponible"
                    : "Alquilado")

                </td>

                <td>@item.PrecioHora</td>

                <td>

                    <a asp-action="Editar"
                       asp-route-id="@item.Id"
                       class="btn btn-warning">

                        Editar

                    </a>

                </td>


                @if (item.Estado == 1)
                {
                    <a asp-controller="Alquileres"
                       asp-action="Alquilar"
                       asp-route-id="@item.Id"
                       class="btn btn-success">

                        Alquilar

                    </a>
                }

            </tr>
        }

    </tbody>

</table>