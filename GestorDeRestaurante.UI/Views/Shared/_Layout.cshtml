<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestor de Restaurante</title>
    <link rel="shortcut icon" href="~/icon.ico" type="image/x-icon" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
    @if (!Context.Request.Path.StartsWithSegments("/Cuentas/Login"))
    {
        <div class="app-container">
            <aside class="sidebar">
                <div class="sidebar-brand">
                    <div @* class="bg-white rounded-circle" style="width:10px; height:20px;" *@></div>
                    <a href="/" style="text-decoration: none; color: inherit;"> Gestor de Restaurante </a>
                </div>

                <div class="nav-content">
                    @* <div class="nav-group">
                        <span class="nav-label">Principal</span>
                        <a class="nav-link-saas @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                           asp-controller="Home" asp-action="Index">
                            <i class="bi bi-grid-1x2"></i> Dashboard
                        </a>
                    </div> *@

                    @if (User.IsInRole("Administrador"))
                    {
                        <div class="nav-group">
                            <span class="nav-label">Administración</span>
                            <a class="nav-link-saas" asp-controller="Usuarios" asp-action="Index"><i class="bi bi-people"></i> Usuarios</a>
                            <a class="nav-link-saas" asp-controller="Menu" asp-action="Index"><i class="bi bi-card-list"></i> Menú</a>
                            <a class="nav-link-saas"asp-controller="Ingredientes"asp-action="Index"><i class="bi bi-box-seam"></i> Ingredientes</a>
                            <a class="nav-link-saas" asp-controller="Recetas" asp-action="Index"><i class="bi bi-journal-text"></i> Recetas</a>
                            <a class="nav-link-saas" asp-controller="Historial" asp-action="Index"><i class="bi bi-graph-up"></i> Historial</a>
                        </div>
                    }

                    @if (User.IsInRole("Empleado") || User.IsInRole("Administrador"))
                    {
                        <div class="nav-group">
                            <span class="nav-label">Operaciones</span>
                            <a class="nav-link-saas" asp-controller="Pedido" asp-action="Index"><i class="bi bi-receipt"></i> Pedidos</a>
                            <a class="nav-link-saas" asp-controller="Facturacion" asp-action="Index"><i class="bi bi-cash-stack"></i> Facturación</a>
                            
                        </div>
                    }
                    @if (User.IsInRole("Empleado") && !User.IsInRole("Administrador"))
                    {
                        <div class="nav-group">
                            <span class="nav-label">Consulta</span>
                            <a class="nav-link-saas" asp-controller="Menu" asp-action="Index"><i class="bi bi-card-list"></i> Menú</a>
                        </div>
                    }
                    @if (User.IsInRole("Cocina"))
                    {
                        <div class="nav-group">
                            <span class="nav-label">Producción</span>
                            <a class="nav-link-saas" asp-controller="Cocina" asp-action="Index"><i class="bi bi-fire"></i> Cocina</a>
                            <a class="nav-link-saas" asp-controller="TableroCocina" asp-action="Index"><i class="bi bi-table"></i> Tablero</a>
                        </div>
                    }
                </div>

                <div class="profile-section">
                    <div class="dropdown">
                        <a class="nav-link-saas justify-content-between cursor-pointer"
                           href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false"
                           style="cursor: pointer;">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-white rounded-circle d-flex align-items-center justify-content-center shadow-sm"
                                     style="width: 32px; height: 32px; min-width: 32px;">
                                    <i class="bi bi-person-fill text-dark" style="font-size: 0.9rem;"></i>
                                </div>
                                <div class="text-start">
                                    <div style="font-size: 0.85rem; font-weight: 500; color: var(--text-primary); line-height: 1;">
                                        @User.Identity!.Name
                                    </div>
                                    <div style="font-size: 0.7rem; color: var(--text-secondary);">
                                        @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                    </div>
                                </div>
                            </div>
                            <i class="bi bi-chevron-down" style="font-size: 0.7rem; color: var(--text-secondary);"></i>
                        </a>

                        <ul class="dropdown-menu dropdown-menu-dark shadow-lg"
                            aria-labelledby="profileDropdown"
                            style="background-color: var(--bg-card); border: 1px solid var(--border-color); margin-left: 0.5rem; min-width: 200px;">
                            <li>
                                <a class="dropdown-item py-2" asp-controller="Cuentas" asp-action="CambiarContrasena"
                                   style="font-size: 0.85rem; color: var(--text-secondary);">
                                    <i class="bi bi-key me-2"></i> Cambiar Contraseña
                                </a>
                            </li>
                            <li><hr class="dropdown-divider" style="border-color: var(--border-color);"></li>
                            <li>
                                <form asp-controller="Cuentas" asp-action="Logout" method="post">
                                    <button type="submit" class="dropdown-item py-2 text-danger" style="font-size: 0.85rem;">
                                        <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </aside>

            <main class="main-content">
                <button id="sidebarToggle" class="btn d-lg-none mb-4" style="background: var(--bg-card); color: white; border: 1px solid var(--border-color);">
                    <i class="bi bi-list"></i> Menú
                </button>
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <script>
            document.addEventListener("DOMContentLoaded", function() {
                const toggleBtn = document.getElementById('sidebarToggle');
                const sidebar = document.querySelector('.sidebar');
                const overlay = document.getElementById('sidebarOverlay');

                if (toggleBtn) {
                    toggleBtn.addEventListener('click', function() {
                        sidebar.classList.toggle('open');
                        overlay.classList.toggle('active');
                    });
                }

                if (overlay) {
                    overlay.addEventListener('click', function() {
                        sidebar.classList.remove('open');
                        overlay.classList.remove('active');
                    });
                }
            });
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
