@model GestorDeRestaurante.Dominio.Entidades.Pedido

@{
    ViewData["Title"] = "Cancelar pedido";
    bool mostrarAdvertencia = ViewBag.MostrarAdvertenciaPlatillos ?? false;
}

<div class="container-fluid d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="col-11 col-sm-8 col-md-6 col-lg-5">
        <div class="saas-card shadow-lg" style="border-radius: 12px;">
            <div class="mb-4">
                <h3 style="font-weight: 700; font-size: 1.4rem; margin: 0;">Cancelar pedido</h3>
            </div>

            <form asp-action="Cancel" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 0.85rem;"></div>

                @* <div class="mb-3 pb-3 border-bottom" style="border-color: var(--border-color) !important;">
                    <div class="mb-2">
                        <span class="text-dim" style="font-size: 0.8rem;">Pedido:</span>
                        <span style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">@Model.Id</span>
                    </div>
                    <div class="mb-2">
                        <span class="text-dim" style="font-size: 0.8rem;">Cliente:</span>
                        <span style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">@Model.NombreDelCliente</span>
                    </div>
                    <div class="mb-2">
                        <span class="text-dim" style="font-size: 0.8rem;">Mesa:</span>
                        <span style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">Mesa @Model.NumeroDeMesa</span>
                    </div>
                    <div class="mb-2">
                        <span class="text-dim" style="font-size: 0.8rem;">Tipo de servicio:</span>
                        <span style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">@Model.TipoDePedido</span>
                    </div>
                    <div>
                        <span class="text-dim" style="font-size: 0.8rem;">Apertura:</span>
                        <span style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">@Model.FechaDeCreacion.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                </div> *@

                @if (mostrarAdvertencia)
                {
                    <div class="mb-4 p-3 bg-dark border border-secondary" style="border-radius: 6px;">
                        <div class="text-danger fw-bold mb-2" style="font-size: 0.85rem;">Acción Requerida</div>
                        <p class="text-dim mb-3" style="font-size: 0.8rem; line-height: 1.4;">
                            @ViewBag.MensajeAdvertencia
                        </p>
                        <div class="form-check form-switch">
                            <input class="form-check-input bg-dark border-secondary" type="checkbox" id="ignorarAdvertenciaPlatillosAtendidos" name="ignorarAdvertenciaPlatillosAtendidos" value="true" required />
                            <label class="form-check-label text-white small" for="ignorarAdvertenciaPlatillosAtendidos" style="font-size: 0.75rem; font-weight: 500;">
                                Confirmar y forzar la cancelación a pesar de los elementos servidos.
                            </label>
                        </div>
                    </div>
                }
                else
                {
                    <input type="hidden" name="ignorarAdvertenciaPlatillosAtendidos" value="false" />
                }

                <div class="mb-4">
                    <label for="motivoDeLaCancelacion" class="form-label text-dim" style="font-size: 0.8rem;">Motivo de la cancelación</label>
                    <textarea id="motivoDeLaCancelacion" name="motivoDeLaCancelacion" rows="4" required
                              class="form-control bg-dark text-white border-secondary" style="resize: none;"
                              placeholder="Describa de forma clara la razón por la cual se anula la comanda (Mínimo 10 caracteres)...">@(HttpMethods.IsPost(Context.Request.Method) ? Context.Request.Form["motivoDeLaCancelacion"].ToString() : "")</textarea>

                    @if (ViewData.ModelState["motivoDeLaCancelacion"]?.Errors.Count > 0)
                    {
                        <span class="text-danger small d-block mt-1" style="font-size: 0.80rem;">
                            @ViewData.ModelState["motivoDeLaCancelacion"]!.Errors[0].ErrorMessage
                        </span>
                    }
                    <div class="text-dim mt-1" style="font-size: 0.75rem;">
                        Rango obligatorio: 10 a 500 caracteres.
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn-saas py-2" style="background-color: #dc3545 !important;">Cancelar pedido</button>
                    <a asp-action="Index" class="btn btn-outline-secondary text-dim" style="border-color: var(--border-color);">Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}