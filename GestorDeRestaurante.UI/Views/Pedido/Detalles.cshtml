@{
    ViewData["Title"] = "Detalles del pedido";
    var pedido = ViewBag.Pedido as GestorDeRestaurante.Dominio.Entidades.Pedido;
    var detallesPedido = ViewBag.DetallesPedido as List<GestorDeRestaurante.Dominio.Entidades.PedidoDetalle>;
    var platillosDisponibles = ViewBag.PlatillosDisponibles as List<GestorDeRestaurante.Dominio.Entidades.Platillo>;
    decimal totalGeneralPedido = ViewBag.TotalGeneralPedido ?? 0;

    if (pedido == null)
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle"></i> Error: Pedido no encontrado.
        </div>
        return;
    }
}

<div class="container-fluid py-4">
    <div class="col-12 mx-auto">
        <div class="saas-card shadow-lg p-4">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-circle"></i> <strong>Error:</strong> @TempData["Error"]
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["Exito"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle"></i> <strong>Éxito:</strong> @TempData["Exito"]
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="mb-4">
                <h3 class="fw-bold m-0">
                    <i class="bi bi-receipt"></i> Detalles del Pedido
                </h3>
                <small class="text-white-50">
                    Pedido #@pedido.Id | Cliente: <strong>@pedido.NombreDelCliente</strong> | Mesa: <strong>@pedido.NumeroDeMesa</strong>
                </small>
            </div>

            <div class="row g-3 mb-5">
                <div class="col-md-6">
                    <div class="card h-100 bg-opacity-10 bg-secondary border-secondary">
                        <div class="card-body p-3">
                            <h6 class="card-title text-light fw-bold mb-3 text-uppercase small">
                                <i class="bi bi-info-circle text-info"></i> Información General
                            </h6>
                            <div class="text-white-50 small">
                                <p class="mb-1"><strong class="text-light">Cliente:</strong> @pedido.NombreDelCliente</p>
                                <p class="mb-1"><strong class="text-light">Mesa:</strong> @pedido.NumeroDeMesa</p>
                                <p class="mb-1"><strong class="text-light">Tipo:</strong> @Html.DisplayFor(modelItem => pedido.TipoDePedido)</p>
                                <p class="mb-1"><strong class="text-light">Fecha:</strong> @pedido.FechaDeCreacion.ToString("dd/MM/yyyy HH:mm")</p>
                                
                                <p class="mb-0">
                                    <strong class="text-light">Observaciones:</strong>
                                    <span>@(string.IsNullOrWhiteSpace(pedido.Observaciones) ? "Sin observaciones" : pedido.Observaciones)</span>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100 bg-opacity-10 bg-secondary border-secondary">
                        <div class="card-body p-3 d-flex flex-column justify-content-between">
                            <div>
                                <h6 class="card-title text-light fw-bold mb-3 text-uppercase small">
                                    <i class="bi bi-gear text-warning"></i> Estado del Pedido
                                </h6>
                                <div>
                                    @{
                                        var estadoClass = pedido.Estado switch
                                        {
                                            GestorDeRestaurante.Dominio.Entidades.EstadoPedido.Pendiente => "bg-warning text-dark",
                                            GestorDeRestaurante.Dominio.Entidades.EstadoPedido.Atendido => "bg-info text-white",
                                            GestorDeRestaurante.Dominio.Entidades.EstadoPedido.Facturado => "bg-success text-white",
                                            GestorDeRestaurante.Dominio.Entidades.EstadoPedido.Cancelado => "bg-danger text-white",
                                            _ => "bg-secondary text-white"
                                        };
                                    }
                                    <span class="badge @estadoClass px-3 py-2 fw-bold">
                                        @Html.DisplayFor(modelItem => pedido.Estado)
                                    </span>
                                </div>
                            </div>
                            <div class="mt-3 border-top border-secondary border-opacity-25 pt-3">
                                <div class="mb-2">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <small class="text-white-50 text-uppercase fw-bold small">Subtotal:</small>
                                        <span class="text-white fw-bold">
                                            @{
                                                var subtotal = ViewBag.Subtotal ?? 0m;
                                            }
                                            @subtotal.ToString("C2", new System.Globalization.CultureInfo("es-CR"))
                                        </span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <small class="text-white-50 text-uppercase fw-bold small">Impuesto (13%):</small>
                                        <span class="text-warning fw-bold">
                                            @{
                                                var impuesto = ViewBag.Impuesto ?? 0m;
                                            }
                                            @impuesto.ToString("C2", new System.Globalization.CultureInfo("es-CR"))
                                        </span>
                                    </div>
                                </div>
                                <div class="border-top border-secondary border-opacity-25 pt-2">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <strong class="text-white text-uppercase small">Total del Pedido:</strong>
                                        <span class="text-success fw-bold fs-5">@totalGeneralPedido.ToString("C2", new System.Globalization.CultureInfo("es-CR"))</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mb-5">
               <h5 class="mb-3 fw-bold">
                   <i class="bi bi-cart-check text-success"></i> Platillos Agregados
               </h5>

               <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0" id="tablaPlatillosAgregados">
                        <thead>
                            <tr class="text-white-50 small text-uppercase border-bottom border-secondary">
                                <th class="p-3">Nombre del Platillo</th>
                                <th class="p-3 text-center">Cantidad</th>
                                <th class="p-3 text-end">Precio Unitario</th>
                                <th class="p-3 text-end">Total Línea</th>
                                <th class="p-3 text-center">Estado en Cocina</th>
                                <th class="p-3 text-center">Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (detallesPedido == null || !detallesPedido.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-white-50 py-4 small">
                                        No hay platillos agregados a este pedido todavía.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in detallesPedido)
                                {
                                    decimal precioUnitario = item.Platillo?.PrecioDeVenta ?? 0;
                                    decimal totalPorLinea = precioUnitario * item.Cantidad;

                                    <tr class="border-bottom border-secondary border-opacity-25">
                                        <td class="p-3">
                                            <div class="fw-bold text-white">@item.Platillo?.Nombre</div>
                                            @if (!string.IsNullOrEmpty(item.Observaciones))
                                            {
                                                <div class="text-white-50 mt-1 small fst-italic">
                                                    <i class="bi bi-chat-left-dots me-1"></i>Observaciones: @item.Observaciones
                                                </div>
                                            }
                                        </td>
                                        <td class="p-3 text-center">
                                            <span class="badge bg-dark border border-secondary text-white fw-bold px-3 py-1">
                                                @item.Cantidad
                                            </span>
                                        </td>
                                        <td class="p-3 text-end text-white">
                                            @precioUnitario.ToString("C", new System.Globalization.CultureInfo("es-CR"))
                                        </td>
                                        <td class="p-3 text-end text-success fw-bold">
                                            @totalPorLinea.ToString("C", new System.Globalization.CultureInfo("es-CR"))
                                        </td>
                                        <td class="p-3 text-center">
                                            @{
                                                var estadoDetalle = item.Estado switch
                                                {
                                                    GestorDeRestaurante.Dominio.Entidades.EstadoDePlatilloEnCocina.Pendiente => "bg-warning text-dark",
                                                    GestorDeRestaurante.Dominio.Entidades.EstadoDePlatilloEnCocina.EnPreparacion => "bg-info text-white",
                                                    GestorDeRestaurante.Dominio.Entidades.EstadoDePlatilloEnCocina.Atendido => "bg-success text-white",
                                                    _ => "bg-secondary text-white"
                                                };
                                                bool puedeEliminar = item.Estado == GestorDeRestaurante.Dominio.Entidades.EstadoDePlatilloEnCocina.Pendiente;
                                            }
                                            <span class="badge @estadoDetalle">
                                                @Html.DisplayFor(modelItem => item.Estado)
                                            </span>
                                        </td>
                                        <td class="p-3 text-center">
                                            @if (puedeEliminar)
                                            {
                                                <form method="post" asp-action="EliminarPlatillo" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="idPedido" value="@pedido.Id" />
                                                    <input type="hidden" name="idPedidoDetalle" value="@item.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger px-2" onclick="return confirm('¿Está seguro de que desea eliminar este platillo del pedido?');">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary text-white-50 opacity-75" title="No se pueden eliminar platillos en preparación o listos">
                                                    <i class="bi bi-lock-fill"></i>
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (pedido.Estado != GestorDeRestaurante.Dominio.Entidades.EstadoPedido.Cancelado && 
                 pedido.Estado != GestorDeRestaurante.Dominio.Entidades.EstadoPedido.Facturado)
            {
                <div class="saas-card p-4 mt-5">
                    <h5 class="mb-4 text-white fw-bold">
                        <i class="bi bi-plus-circle text-primary me-2"></i>Agregar Platillo al Pedido
                    </h5>
                    <form method="get" asp-action="Detalles" asp-route-id="@pedido.Id" class="mb-4">
                        <div class="row g-2">
                            <div class="col-md-6">
                                <input type="text" name="nombrePlatillo" value="@ViewBag.NombreFiltro"
                                       class="form-control bg-dark text-white border-secondary"
                                       placeholder="Filtrar por nombre de platillo..." style="font-size: 0.85rem;" />
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-outline-secondary w-100 text-white" style="font-size: 0.85rem;">
                                    <i class="bi bi-search"></i> Filtrar
                                </button>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(ViewBag.NombreFiltro))
                            {
                                <div class="col-md-2">
                                    <a asp-action="Detalles" asp-route-id="@pedido.Id" class="btn btn-outline-secondary w-100 text-white" style="font-size: 0.85rem;">
                                        <i class="bi bi-x-circle"></i> Limpiar
                                    </a>
                                </div>
                            }
                        </div>
                    </form>

                    <div class="table-responsive">
                        <table class="table table-dark table-hover align-middle">
                            <thead>
                                <tr class="text-white-50 small text-uppercase">
                                    <th class="p-3">Platillo</th>
                                    <th class="p-3">Categoría</th>
                                    <th class="p-3 text-end">Precio</th>
                                    <th class="p-3 text-center">Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (platillosDisponibles == null || !platillosDisponibles.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-white-50 py-4 small">
                                            No hay platillos disponibles para agregar.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var item in platillosDisponibles)
                                    {
                                        <tr>
                                            <td class="p-3 fw-bold text-white">@item.Nombre</td>
                                            <td class="p-3 text-white-50">@item.Categoria</td>
                                            <td class="p-3 text-end text-white">
                                                @item.PrecioDeVenta.ToString("C", new System.Globalization.CultureInfo("es-CR"))
                                            </td>
                                            <td class="p-3 text-center">
                                                <button class="btn btn-sm btn-primary px-3" type="button" data-bs-toggle="collapse" data-bs-target="#form-row-@item.Id">
                                                    <i class="bi bi-plus-lg"></i> Seleccionar
                                                </button>
                                            </td>
                                        </tr>
                                        <tr id="form-row-@item.Id" class="collapse bg-secondary bg-opacity-10">
                                            <td colspan="4" class="p-4">
                                                <div class="card p-3 bg-dark border-secondary">
                                                    <h6 class="text-white mb-3 fw-bold">Configurar Platillo: @item.Nombre</h6>

                                                    <form method="post" asp-action="Detalles">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="idPedido" value="@pedido.Id" />
                                                    <input type="hidden" name="idPlatillo" value="@item.Id" />

                                                    <div class="row g-3">
                                                        <div class="col-md-3">
                                                            <label class="form-label text-white-50 small text-uppercase fw-bold">Cantidad</label>
                                                            <input type="number" name="cantidad" class="form-control bg-dark text-white border-secondary" value="1" min="1" required />
                                                        </div>
                                                        <div class="col-md-9">
                                                            <label class="form-label text-white-50 small text-uppercase fw-bold">Observaciones / Notas de Cocina</label>
                                                            <input type="text" name="observaciones" class="form-control bg-dark text-white border-secondary" placeholder="Ej: Término medio, sin tomate..." />
                                                        </div>
                                                        <div class="col-12 d-flex gap-2 justify-content-end mt-3">
                                                            <button type="button" class="btn btn-sm btn-outline-secondary w-50 fw-bold" data-bs-toggle="collapse" data-bs-target="#form-row-@item.Id">
                                                                Cancelar
                                                            </button>
                                                            <button type="submit" class="btn btn-sm btn-success w-50 fw-bold">
                                                                <i class="bi bi-check-circle"></i> Agregar
                                                            </button>
                                                        </div>
                                                    </div>
                                                </form>

                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            }
            else
            {
                <div class="alert alert-warning alert-dismissible fade show mt-5" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Advertencia:</strong> Este pedido está en estado <strong>@pedido.Estado</strong> y no se pueden agregar más platillos.
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="mt-4 pt-3 border-top border-secondary border-opacity-25">
                <a asp-action="Index" class="btn btn-secondary px-4">
                    <i class="bi bi-arrow-left"></i> Volver a la Lista
                </a>
            </div>

        </div>
    </div>
</div>