@model IEnumerable<GestorDeRestaurante.Dominio.Entidades.Platillo>

@{
    ViewData["Title"] = "Gestión del Menú";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 style="font-weight: 700; font-size: 1.5rem; margin: 0;">Gestión del menú</h2>
        <p class="text-dim mb-0">Módulo para la gestión de los platillos que ofrece el restaurante.</p>
    </div>
    @if (User.IsInRole("Administrador"))
    {
        <a asp-action="Create" class="btn-saas text-decoration-none" style="display: inline-flex; align-items: center; gap: 8px;">
            <i class="bi bi-plus-circle"></i> Nuevo platillo
        </a>
    }
</div>

<div class="mb-4">
    <form asp-action="Index" method="get" class="d-flex gap-2">
        <div class="position-relative flex-grow-1" style="max-width: 400px;">
            <i class="bi bi-search position-absolute" style="left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-secondary); font-size: 0.9rem;"></i>
            <input name="nombre" type="text" class="form-control bg-dark text-white border-secondary ps-5"
                   placeholder="Buscar platillo por nombre..."
                   style="font-size: 0.85rem; height: 38px; --bs-secondary-color: var(--text-secondary); --bs-form-control-bg: var(--bg-card);"/>
        </div>
        <button type="submit" class="btn-saas px-3 text-decoration-none"> Filtrar</button>
    </form>
</div>

<div class="saas-card p-0 overflow-hidden" style="padding: 0; border-radius: 8px;">

    <div class="d-flex align-items-center px-3 py-2 border-bottom flex-shrink-0 text-center"
         style="border-color: var(--border-color) !important; background-color: rgba(255,255,255,0.03); font-size: 0.7rem; 
                color: var(--text-secondary); font-weight: 600;">
        <div style="width: 20%">Nombre</div>
        <div style="width: 30%">Descripción</div>
        <div style="width: 15%">Categoría</div>
        <div style="width: 15%">Precio</div>
        <div style="width: 10%">Estado</div>
        <div style="width: 10%">Acciones</div>
    </div>

    <div class="list-group list-group-flush">
        @foreach (var item in Model)
        {
            <div class="list-group-item bg-transparent border-secondary d-flex align-items-center px-3 py-3 flex-shrink-0 text-center"
                 style="border-color: var(--border-color) !important; cursor: default; font-size: 0.85rem; color: var(--text-primary);">

                <div style="width: 20%">@item.Nombre</div>
                <div style="width: 30%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding-right: 15px;">@item.Descripcion</div>
                <div style="width: 15%;">@item.Categoria</div>
                <div style="width: 15%">
                    @item.PrecioDeVenta.ToString("C2", new System.Globalization.CultureInfo("es-CR"))
                </div>
                <div style="width: 10%; text-align: center;">
                    @if (item.Estado.ToString() == "Disponible")
                    {
                        <span class="badge rounded-pill bg-dark border border-secondary text-success" style="font-size: 0.7rem; padding: 0.4em 0.8em;">
                            Disponible
                        </span>
                    }
                    else
                    {
                        <span class="badge rounded-pill bg-dark border border-secondary text-danger" style="font-size: 0.7rem; padding: 0.4em 0.8em; background-color: rgba(220, 53, 69, 0.05) !important;">
                            No disponible
                        </span>
                    }
                </div>
                <div class="flex-shrink-0 text-center" style="width: 10%; text-align: right;">
                    @if (User.IsInRole("Administrador"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-info px-2 py-1"
                           style="font-size: 0.8rem; border-radius: 4px;">
                            <i class="bi bi-pencil-square"></i> Editar
                        </a>
                    }
                    else
                    {
                        <span class="badge rounded-pill bg-dark border border-secondary text-dim" style="font-size: 0.7rem; padding: 0.4em 0.8em; opacity: 0.7;">
                            <i class="bi bi-lock-fill"></i> Bloqueado
                        </span>
                    }
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-dim" style="font-size: 0.85rem;">
                <i class="bi bi-egg-fried d-block mb-2" style="font-size: 2rem; opacity: 0.5;"></i>
                No se encontraron platillos registrados en el sistema.
            </div>
        }
    </div>
</div>