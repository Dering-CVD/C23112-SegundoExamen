@model GestorDeRestaurante.Dominio.Entidades.Platillo

@{
    ViewData["Title"] = "Agregar platillo";
}

<div class="container-fluid d-flex align-items-center justify-content-center" style="min-height: 85vh; py-4;">
    <div class="col-11 col-sm-10 col-md-8 col-lg-6">
        
        <div class="saas-card shadow-lg p-4" style="border-radius: 12px;">
            
            <div class="mb-4">
                <h3 style="font-weight: 700; font-size: 1.4rem; margin: 0;">Agregar platillo</h3>
            </div>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 0.85rem;"></div>

                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label text-dim fw-bold" style="font-size: 0.8rem;"></label>
                    <input asp-for="Nombre" class="form-control bg-dark text-white border-secondary"
                           placeholder="Ej: Arroz con pollo" style="font-size: 0.9rem;" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Descripcion" class="form-label text-dim fw-bold" style="font-size: 0.8rem;">Descripción</label>
                    <textarea asp-for="Descripcion" class="form-control bg-dark text-white border-secondary"
                              rows="3" placeholder="Escriba los detalles o presentación del platillo..." style="font-size: 0.9rem;"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PrecioDeVenta" class="form-label text-dim fw-bold" style="font-size: 0.8rem;">Precio de venta</label>
                    <div class="input-group">
                        <span class="input-group-text bg-secondary border-secondary text-white" style="font-size: 0.9rem;">₡</span>
                        <input asp-for="PrecioDeVenta" class="form-control bg-dark text-white border-secondary"
                               type="number" step="0.01" placeholder="0.00" style="font-size: 0.9rem;" />
                    </div>
                    <span asp-validation-for="PrecioDeVenta" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Categoria" class="form-label text-dim fw-bold" style="font-size: 0.8rem;">Categoría</label>
                    <select asp-for="Categoria" class="form-control bg-dark text-white border-secondary" style="font-size: 0.9rem;"
                            asp-items="Html.GetEnumSelectList<GestorDeRestaurante.Dominio.Entidades.Categoria>()">
                        <option value="" class="text-muted">-- Seleccione una categoría --</option>
                    </select>
                    <span asp-validation-for="Categoria" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Observaciones" class="form-label text-dim fw-bold" style="font-size: 0.8rem;"></label>
                    <input asp-for="Observaciones" class="form-control bg-dark text-white border-secondary"
                           placeholder="Notas internas opcionales (Ej: No incluye acompañamiento)" style="font-size: 0.9rem;" />
                    <span asp-validation-for="Observaciones" class="text-danger small"></span>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn-saas py-2">
                         Registrar platillo
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary text-dim" style="border-color: var(--border-color);">
                        Cancelar
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
