@model IEnumerable<GestorDeRestaurante.Dominio.Dtos.CocinaDto.ListarPedidosPendientesDto>

@{
    ViewData["Title"] = "Cocina - Pendientes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 style="font-weight: 700; font-size: 1.5rem; margin: 0;">Cocina</h2>
        <p class="text-dim">Módulo para la gestión y preparación de los platillos pendientes.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="" class="btn-saas text-decoration-none active" style="display: inline-flex; align-items: center; gap: 8px; background-color: rgba(255,255,255,0.15);">
            <i class="bi bi-list-task"></i> Pendientes
        </a>
        <a asp-action="EnPreparacion" class="btn-saas text-decoration-none" style="display: inline-flex; align-items: center; gap: 8px;">
            <i class="bi bi-clock-history"></i> En preparación
        </a>
        <a asp-action="Atendidos" class="btn-saas text-decoration-none" style="display: inline-flex; align-items: center; gap: 8px;">
            <i class="bi bi-check-circle"></i> Atendidos
        </a>
    </div>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert" style="background-color: rgba(220, 53, 69, 0.1); border-color: rgba(220, 53, 69, 0.3); color: #ff6b6b; font-size: 0.85rem; border-radius: 6px;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert" style="background-color: rgba(25, 135, 84, 0.1); border-color: rgba(25, 135, 84, 0.3); color: #47d68a; font-size: 0.85rem; border-radius: 6px;">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="mb-4">
    <form method="get" class="d-flex gap-2">
        <div class="position-relative flex-grow-1" style="max-width: 400px;">
            <i class="bi bi-search position-absolute" style="left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-secondary); font-size: 0.9rem;"></i>
            <input name="buscar" type="text" class="form-control bg-dark text-white border-secondary ps-5"
                   placeholder="Buscar por nombre del platillo..."
                   style="font-size: 0.85rem; height: 38px; --bs-secondary-color: var(--text-secondary); --bs-form-control-bg: var(--bg-card);" />
        </div>
        <button type="submit" class="btn-saas px-3 text-decoration-none">Filtrar</button>
    </form>
</div>

<div class="saas-card p-0 overflow-hidden" style="padding: 0; border-radius: 8px;">

    <div class="d-flex align-items-center px-3 py-2 border-bottom flex-shrink-0"
         style="border-color: var(--border-color) !important; background-color: rgba(255,255,255,0.03); font-size: 0.7rem;
        color: var(--text-secondary); font-weight: 600;">
        <div style="width: 13%">Número de pedido</div>
        <div style="width: 20%">Fecha y hora del pedido</div>
        <div style="width: 20%">Nombre del platillo</div>
        <div style="width: 10%">Cantidad</div>
        <div style="width: 20%">Observación del platillo</div>
        <div style="width: 10%">Tipo de pedido</div>
        <div style="width: 10%; text-align: right;">Acciones</div>
    </div>

    <div class="list-group list-group-flush">
        @foreach (var item in Model)
        {
            <div class="list-group-item bg-transparent border-secondary d-flex align-items-center px-3 py-3 flex-shrink-0"
                 style="border-color: var(--border-color) !important; cursor: default; font-size: 0.85rem; color: var(--text-primary)">

                <div style="width: 13%;">@item.IdPedido</div>
                <div style="width: 20%;">@item.FechaDeRegistro</div>
                <div style="width: 20%;">@item.NombreDelPlatillo</div>
                <div style="width: 10%; font-weight: 600;">@item.Cantidad</div>
                <div style="width: 20%; color: var(--text-secondary);" class="text-truncate">@item.ObservacionDelPlatillo</div>
                <div style="width: 10%;">@Html.DisplayFor(modelItem => item.TipoDePedido)</div>

                <div class="flex-shrink-0" style="width: 10%; text-align: right;">
                    <button type="button" class="btn btn-sm btn-outline-info px-2 py-1"
                            onclick="abrirConfirmacion(@item.Id)" style="font-size: 0.8rem; border-radius: 4px;">
                        <i class="bi bi-play-fill"></i> Preparar
                    </button>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-dim" style="font-size: 0.85rem;">
                <i class="bi bi-fire d-block mb-2" style="font-size: 2rem; opacity: 0.5;"></i>
                No hay platillos pendientes en cocina.
            </div>
        }
    </div>
</div>

<div class="modal fade" id="confirmarCocinaModal" tabindex="-1" style="background-color: rgba(0,0,0,0.85);">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 480px;">
        <div class="modal-content shadow-lg" style="background-color: var(--bg-card); border: 1px solid var(--border-color); border-radius: 12px; color: white;">

            <div class="modal-header px-4 pt-4 pb-2 border-0 position-relative">
                <h5 class="modal-title" style="font-weight: 700; font-size: 1.25rem;">Confirmar Preparación</h5>
                <button type="button" class="btn-close btn-close-white position-absolute" data-bs-dismiss="modal" style="top: 24px; right: 24px; font-size: 0.8rem;"></button>
            </div>

            <div class="modal-body px-4 pb-4">
                <div class="mb-3">
                    <span class="text-dim" style="font-size: 0.8rem; text-transform: uppercase; font-weight: 600; letter-spacing: 0.5px;">Platillo Seleccionado</span>
                    <h4 id="modalPlatillo" style="font-weight: 600; font-size: 1.15rem; margin-top: 4px; color: var(--text-primary);"></h4>
                </div>

                <span class="text-dim d-block mb-2" style="font-size: 0.8rem; text-transform: uppercase; font-weight: 600; letter-spacing: 0.5px;">Ingredientes Requeridos</span>

                <div class="border" style="border-color: var(--border-color) !important; border-radius: 6px; overflow: hidden; background-color: rgba(0,0,0,0.15);">
                    <div class="d-flex px-3 py-2 border-bottom" style="border-color: var(--border-color) !important; background-color: rgba(255,255,255,0.02); font-size: 0.75rem; font-weight: 600; color: var(--text-secondary);">
                        <div style="width: 60%;">Ingrediente</div>
                        <div style="width: 40%; text-align: right;">Cantidad / Unidad</div>
                    </div>
                    <div id="listaIngredientes" class="overflow-auto" style="max-height: 200px; font-size: 0.85rem;">
                    </div>
                </div>
            </div>

            <div class="modal-footer px-4 pb-4 pt-0 border-0 d-flex gap-2">
                <button type="button" class="btn btn-outline-secondary text-dim flex-grow-1 py-2" data-bs-dismiss="modal" style="border-color: var(--border-color); font-size: 0.85rem;">Cancelar</button>
                <button type="button" id="btnConfirmarInicio" class="btn-saas flex-grow-1 py-2" style="font-size: 0.85rem; font-weight: 600;">Iniciar Preparación</button>
            </div>

        </div>
    </div>
</div>

<script>
    async function abrirConfirmacion(id) {
        try {
            const response = await fetch(`/Cocina/ObtenerDetallesReceta?idDetalle=${id}`);
            if (!response.ok) throw new Error("No se pudo cargar la receta");

            const data = await response.json();

            document.getElementById('modalPlatillo').innerText = data.nombrePlatillo;

            const contenedorIngredientes = document.getElementById('listaIngredientes');
            contenedorIngredientes.innerHTML = '';

            if (!data.ingredientes || data.ingredientes.length === 0) {
                contenedorIngredientes.innerHTML = `
                    <div class="text-center py-3 text-dim" style="font-size: 0.8rem;">
                        No se definieron ingredientes específicos para esta receta.
                    </div>`;
            } else {
                data.ingredientes.forEach((ing, index) => {
                    const lineBorder = index < data.ingredientes.length - 1 ? 'border-bottom' : '';
                    const itemRow = `
                        <div class="d-flex px-3 py-2 ${lineBorder}" style="border-color: var(--border-color) !important; color: var(--text-primary);">
                            <div style="width: 60%; font-weight: 500;">${ing.nombre}</div>
                            <div style="width: 40%; text-align: right; color: var(--text-secondary); font-family: monospace;">${ing.cantidad} ${ing.unidadMedida}</div>
                        </div>`;
                    contenedorIngredientes.innerHTML += itemRow;
                });
            }

            document.getElementById('btnConfirmarInicio').onclick = function() {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '/Cocina/IniciarPreparacion';
                form.innerHTML = `<input type="hidden" name="id" value="${id}">`;
                document.body.appendChild(form);
                form.submit();
            };

            const modal = new bootstrap.Modal(document.getElementById('confirmarCocinaModal'));
            modal.show();

        } catch (error) {
            alert("Error al obtener la receta: " + error.message);
        }
    }

</script>