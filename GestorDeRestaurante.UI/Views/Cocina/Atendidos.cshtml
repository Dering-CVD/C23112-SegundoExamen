@model IEnumerable<GestorDeRestaurante.Dominio.Dtos.CocinaDto.ListarPedidosAtendidosDto>

@{
    ViewData["Title"] = "Cocina - Historial";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 style="font-weight: 700; font-size: 1.5rem; margin: 0;">Cocina</h2>
        <p class="text-dim">Historial de platillos que ya han sido despachados y atendidos.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn-saas text-decoration-none" style="display: inline-flex; align-items: center; gap: 8px;">
            <i class="bi bi-list-task"></i> Pendientes
        </a>
        <a asp-action="EnPreparacion" class="btn-saas text-decoration-none" style="display: inline-flex; align-items: center; gap: 8px;">
            <i class="bi bi-clock-history"></i> En preparación
        </a>
        <a asp-action="Atendidos" class="btn-saas text-decoration-none active" style="display: inline-flex; align-items: center; gap: 8px; background-color: rgba(255,255,255,0.15);">
            <i class="bi bi-check-circle"></i> Atendidos
        </a>
    </div>
</div>

<div class="mb-4">
    <form method="get" class="d-flex gap-2">
        <div class="position-relative flex-grow-1" style="max-width: 400px;">
            <i class="bi bi-search position-absolute" style="left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-secondary); font-size: 0.9rem;"></i>
            <input name="buscar" type="text" class="form-control bg-dark text-white border-secondary ps-5"
                   placeholder="Buscar por nombre del platillo..."
                   style="font-size: 0.85rem; height: 38px; --bs-secondary-color: var(--text-secondary); --bs-form-control-bg: var(--bg-card);" />
        </div>
        <button type="submit" class="btn-saas px-3 text-decoration-none">Filtrar</button>
    </form>
</div>

<div class="saas-card p-0 overflow-hidden" style="padding: 0; border-radius: 8px;">

    <div class="d-flex align-items-center px-3 py-2 border-bottom flex-shrink-0 text-center"
         style="border-color: var(--border-color) !important; background-color: rgba(255,255,255,0.03); font-size: 0.7rem;
         color: var(--text-secondary); font-weight: 600;">
        <div style="width: 15%">Número de pedido</div>
        <div style="width: 35%">Platillo</div>
        <div style="width: 15%">Cantidad</div>
        <div style="width: 35%">Fecha y hora de atención</div>
    </div>

    <div class="list-group list-group-flush">
        @foreach (var item in Model)
        {
            <div class="list-group-item bg-transparent border-secondary d-flex align-items-center px-3 py-3 flex-shrink-0 opacity-75 text-center"
                 style="border-color: var(--border-color) !important; cursor: default; font-size: 0.85rem; color: var(--text-primary)">

                <div style="width: 15%; ">@item.IdPedido</div>
                <div style="width: 35%; font-weight: 500;">@item.NombreDelPlatillo</div>
                <div style="width: 15%; font-weight: 500;">@item.Cantidad</div>
                <div style="width: 35%; ">@item.FechaDeAtencion</div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-dim" style="font-size: 0.85rem;">
                <i class="bi bi-archive d-block mb-2" style="font-size: 2rem; opacity: 0.5;"></i>
                No se registran platillos completados el día de hoy.
            </div>
        }
    </div>
</div>