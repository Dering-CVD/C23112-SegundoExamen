@model List<GestorDeRestaurante.Dominio.Entidades.Ingrediente>

@{
    ViewData["Title"] = "Gestión de ingredientes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 style="font-weight: 700; font-size: 1.5rem; margin: 0;">Gestión de ingredientes</h2>
        <p class="text-dim">Módulo para el control de existencias, stock, costos de insumos e inventario general.</p>
    </div>
    <a asp-action="Create" class="btn-saas text-decoration-none" style="display: inline-flex; align-items: center; gap: 8px;">
        <i class="bi bi-plus-circle"></i> Nuevo ingrediente
    </a>
</div>

<div class="mb-4">
    <form method="get" class="d-flex gap-2">
        <div class="position-relative flex-grow-1" style="max-width: 400px;">
            <i class="bi bi-search position-absolute" style="left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-secondary); font-size: 0.9rem;"></i>
            <input name="nombre" type="text" class="form-control bg-dark text-white border-secondary ps-5"
                   placeholder="Buscar por nombre..."
                   style="font-size: 0.85rem; height: 38px; --bs-secondary-color: var(--text-secondary); --bs-form-control-bg: var(--bg-card);" />
        </div>
        <button type="submit" class="btn-saas px-3 text-decoration-none"> Filtrar</button>
    </form>
</div>

<div class="saas-card p-0 overflow-hidden" style="padding: 0; border-radius: 8px;">

    <div class="d-flex align-items-center px-3 py-2 border-bottom flex-shrink-0 text-center"
         style="border-color: var(--border-color) !important; background-color: rgba(255,255,255,0.03); font-size: 0.7rem;
                color: var(--text-secondary); font-weight: 600;">
        <div style="width: 20%">Nombre</div>
        <div style="width: 12%">Cantidad disponible</div>
        <div style="width: 10%">Unidad de medida</div>
        <div style="width: 13%">Costo Unitario</div>
        <div style="width: 12%">Cantidad minima</div>
        <div style="width: 10%">Estado</div>
        <div style="width: 23%">Acciones</div>
    </div>

    <div class="list-group list-group-flush">
        @foreach (var item in Model)
        {
            <div class="list-group-item bg-transparent border-secondary d-flex align-items-center px-3 py-3 flex-shrink-0 text-center"
                 style="border-color: var(--border-color) !important; cursor: default; font-size: 0.85rem; color: var(--text-primary);">

                <div style="width: 20%; font-weight: 500;">@item.Nombre</div>

                <div style="width: 12%; font-weight: 600;">@item.CantiadadDisponible</div>

                <div style="width: 10%">@item.UnidadDeMedida</div>

                <div style="width: 13%; font-weight: 600">₡@item.CostoUnitario.ToString("N2")</div>

                <div style="width: 12%">@item.CantidadMinima</div>

                <div style="width: 10%;">
                    @if (item.Estado == 1)
                    {
                        <span class="badge rounded-pill bg-dark border border-secondary text-secondary" style="font-size: 0.7rem; padding: 0.4em 0.8em;">
                            Activo
                        </span>
                    }
                    else
                    {
                        <span class="badge rounded-pill bg-dark border border-secondary text-danger" style="font-size: 0.7rem; padding: 0.4em 0.8em; background-color: rgba(220, 53, 69, 0.05) !important;">
                            Inactivo
                        </span>
                    }
                </div>

                <div class="flex-shrink-0" style="width: 23%; text-align: right; display: flex; gap: 4px; justify-content: flex-end;">
                    <a asp-action="Edit" asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-info px-2 py-1"
                       style="font-size: 0.8rem; border-radius: 4px;">
                        <i class="bi bi-pencil-square"></i> Editar
                    </a>
                    <a asp-action="AjustarInventario" asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-success px-2 py-1"
                       style="font-size: 0.8rem; border-radius: 4px;">
                        <i class="bi bi-sliders"></i> Ajustar
                    </a>
                    @if (item.Estado == 1)
                    {
                        <a asp-action="Inactivar" asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-danger px-2 py-1"
                           style="font-size: 0.8rem; border-radius: 4px;">
                            <i class="bi bi-patch-minus"></i> Inactivar
                        </a>
                    }
                    else
                    {
                        <a asp-action="Activar" asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-secondary text-dim px-2 py-1"
                           style="font-size: 0.8rem; border-radius: 4px; border-color: var(--border-color);">
                            <i class="bi bi-patch-check"></i> Activar
                        </a>
                    }
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-dim" style="font-size: 0.85rem;">
                <i class="bi bi-box-seam d-block mb-2" style="font-size: 2rem; opacity: 0.5;"></i>
                No se encontraron ingredientes registrados en el sistema.
            </div>
        }
    </div>
</div>