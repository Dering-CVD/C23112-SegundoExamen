@model GestorDeRestaurante.Dominio.Entidades.Ingrediente

@{
    ViewData["Title"] = "Ajustar Inventario";
}

<div class="container-fluid d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="col-11 col-sm-8 col-md-6 col-lg-5">
        <div class="saas-card shadow-lg" style="border-radius: 12px;">
            <div class="mb-4">
                <h3 style="font-weight: 700; font-size: 1.4rem; margin: 0;">Ajustar Inventario</h3>
                <p class="text-dim mb-0" style="font-size: 0.85rem;">Incremente o disminuya manualmente las existencias actuales del insumo.</p>
            </div>

            <form asp-action="AjustarInventario" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 0.85rem;"></div>
                
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label text-dim" style="font-size: 0.8rem;">Ingrediente</label>
                    <input value="@Model.Nombre" class="form-control bg-dark text-white border-secondary" readonly 
                           style="opacity: 0.6; cursor: not-allowed;" />
                </div>

                <div class="mb-3">
                    <label class="form-label text-dim" style="font-size: 0.8rem;">Cantidad Disponible Actual</label>
                    <input value="@Model.CantiadadDisponible" class="form-control bg-dark text-white border-secondary" readonly 
                           style="opacity: 0.6; cursor: not-allowed;" />
                </div>

                <div class="mb-3">
                    <label class="form-label text-dim" style="font-size: 0.8rem;">Cantidad para el Ajuste</label>
                    <input type="number" step="1" name="cantidad" id="cantidad"
                           class="form-control bg-dark text-white border-secondary"
                           oninput="this.value = this.value < 0 ? 0 : this.value;" />
                </div>

                <div class="mb-4">
                    <label class="form-label text-dim" style="font-size: 0.8rem;">Tipo de Ajuste</label>
                    <select name="tipo" class="form-select bg-dark text-white border-secondary" required>
                        <option value="Aumento">Aumento (+)</option>
                        <option value="Disminucion">Disminución (-)</option>
                    </select>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn-saas py-2">Guardar Ajuste</button>
                    <a asp-action="Index" class="btn btn-outline-secondary text-dim" style="border-color: var(--border-color);">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}