@model IEnumerable<GestorDeRestaurante.Dominio.Dtos.PedidoFacturableDto>

@{
    ViewData["Title"] = "Pedidos Disponibles para Facturar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 style="font-weight: 700; font-size: 1.5rem; margin: 0;">Módulo de Facturación</h2>
        <p class="text-dim">Pedidos atendidos disponibles para facturar.</p>
    </div>
</div>

@if (TempData["MensajeExito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center" role="alert" style="font-size: 0.85rem;">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["MensajeExito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="font-size: 0.7rem;"></button>
    </div>
}

<div class="saas-card p-0 overflow-hidden" style="padding: 0; border-radius: 8px;">

    <div class="d-flex align-items-center px-3 py-2 border-bottom flex-shrink-0 text-center"
         style="border-color: var(--border-color) !important; background-color: rgba(255,255,255,0.03); font-size: 0.7rem;
                color: var(--text-secondary); font-weight: 600;">
        <div style="width: 15%">Número de pedido</div>
        <div style="width: 15%">Fecha y hora</div>
        <div style="width: 20%">Cliente</div>
        <div style="width: 10%">Mesa</div>
        <div style="width: 15%">Tipo de pedido</div>
        <div style="width: 15%">Total</div>
        <div style="width: 10%">Acciones</div>
    </div>

    <div class="list-group list-group-flush">
        @foreach (var item in Model)
        {
            <div class="list-group-item bg-transparent border-secondary d-flex align-items-center px-3 py-3 flex-shrink-0 text-center"
                 style="border-color: var(--border-color) !important; cursor: default; font-size: 0.85rem; color: var(--text-primary);">

                <div style="width: 15%">@item.IdPedido</div>
                <div style="width: 15%">@item.FechaPedido.ToString("dd/MM/yyyy hh:mm tt")</div>
                <div style="width: 20%">@item.Cliente</div>
                <div style="width: 10%">Mesa @item.Mesa</div>
                <div style="width: 15%">@item.TipoPedido</div>
                <div style="width: 15%">₡@item.Total.ToString("N2")</div>
                <div class="flex-shrink-0" style="width: 10%">
                    <a asp-action="GenerarFactura" asp-route-idPedido="@item.IdPedido"
                       class="btn btn-sm btn-outline-info px-2 py-1"
                       style="font-size: 0.8rem; border-radius: 4px;">
                        <i class="bi bi-currency-dollar"></i> Facturar
                    </a>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-dim" style="font-size: 0.85rem;">
                <i class="bi bi-receipt d-block mb-2" style="font-size: 2rem; opacity: 0.5;"></i>
                No existen pedidos disponibles en estado Atendido para facturar.
            </div>
        }
    </div>
</div>