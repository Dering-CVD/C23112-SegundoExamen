@model GestorDeRestaurante.Dominio.Dtos.FacturaDto

@{
    ViewData["Title"] = "Generar Factura";
}

<div class="mb-3">
    <a asp-action="Index" class="text-decoration-none text-dim" style="font-size: 0.85rem; display: inline-flex; align-items: center; gap: 4px;">
        <i class="bi bi-arrow-left"></i> Volver a la Lista
    </a>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 style="font-weight: 700; font-size: 1.5rem; margin: 0;">Generar factura</h2>
    </div>
</div>

<div class="saas-card p-4 mb-4" style="border-radius: 8px;">

    <h5 style="color: var(--text-primary); font-size: 1rem; margin-bottom: 1rem; font-weight: 600;">Detalle del pedido</h5>
    <div class="d-flex flex-wrap gap-5 mb-4 pb-4 border-bottom" style="border-color: var(--border-color) !important;">
        <div>
            <div style="font-size: 0.7rem; color: var(--text-secondary); font-weight: 600; margin-bottom: 4px;">Número de pedido</div>
            <div style="color: var(--text-primary); font-size: 0.95rem; font-weight: 500;">@Model.IdPedido</div>
        </div>
        <div>
            <div style="font-size: 0.7rem; color: var(--text-secondary); font-weight: 600; margin-bottom: 4px;">Número de mesa</div>
            <div style="color: var(--text-primary); font-size: 0.95rem; font-weight: 500;">Mesa @Model.Mesa</div>
        </div>
        <div>
            <div style="font-size: 0.7rem; color: var(--text-secondary); font-weight: 600; margin-bottom: 4px;">Tipo de pedido</div>
            <div style="color: var(--text-primary); font-size: 0.95rem; font-weight: 500;">@Model.TipoPedido</div>
        </div>
    </div>

    <h5 style="color: var(--text-primary); font-size: 1rem; margin-bottom: 1rem; font-weight: 600;">Detalle de los platillos</h5>
    <div class="saas-card p-0 overflow-hidden mb-4" style="padding: 0; border-radius: 8px; border: 1px solid var(--border-color);">
        <div class="d-flex align-items-center px-3 py-2 border-bottom flex-shrink-0"
             style="border-color: var(--border-color) !important; background-color: rgba(255,255,255,0.03); font-size: 0.7rem;
                    color: var(--text-secondary); font-weight: 600;">
            <div style="width: 40%">Nombre del platillo</div>
            <div style="width: 20%; text-align: center;">Cantidad</div>
            <div style="width: 20%; text-align: right;">Precio unitario</div>
            <div style="width: 20%; text-align: right;">Subtotal</div>
        </div>

        <div class="list-group list-group-flush">
            @foreach (var item in Model.Detalles)
            {
                <div class="list-group-item bg-transparent border-secondary d-flex align-items-center px-3 py-3 flex-shrink-0"
                     style="border-color: var(--border-color) !important; cursor: default; font-size: 0.85rem; color: var(--text-primary);">
                    <div style="width: 40%; font-weight: 500;">@item.NombrePlatillo</div>
                    <div style="width: 20%; text-align: center;">@item.Cantidad</div>
                    <div style="width: 20%; text-align: right;">₡@item.PrecioUnitario.ToString("N2")</div>
                    <div style="width: 20%; font-weight: 600; text-align: right;">₡@item.Subtotal.ToString("N2")</div>
                </div>
            }
        </div>
    </div>

    <div class="d-flex justify-content-end mb-4">
        <div style="width: 300px;">
            <div class="d-flex justify-content-between mb-2" style="font-size: 0.85rem; color: var(--text-secondary);">
                <span>Subtotal:</span>
                <span style="color: var(--text-primary);">₡@Model.Subtotal.ToString("N2")</span>
            </div>
            <div class="d-flex justify-content-between mb-3" style="font-size: 0.85rem; color: var(--text-secondary);">
                <span>Impuesto (13%):</span>
                <span style="color: var(--text-primary);">₡@Model.Impuesto.ToString("N2")</span>
            </div>
            <div class="d-flex justify-content-between pt-3 border-top" style="border-color: var(--border-color) !important; font-size: 1.1rem; font-weight: 700;">
                <span style="color: var(--text-primary);">Total:</span>
                <span style="color: var(--text-primary);">₡@Model.Total.ToString("N2")</span>
            </div>
        </div>
    </div>

    <div class="border-top pt-4 d-flex justify-content-end" style="border-color: var(--border-color) !important;">
        <form asp-action="GenerarFacturaConfirmada" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="idPedido" value="@Model.IdPedido" />
            <button type="submit" class="btn-saas text-decoration-none border-0" style="display: inline-flex; align-items: center; gap: 8px;">
                <i class="bi bi-file-earmark-spreadsheet-fill"></i> Registrar factura
            </button>
        </form>
    </div>
</div>