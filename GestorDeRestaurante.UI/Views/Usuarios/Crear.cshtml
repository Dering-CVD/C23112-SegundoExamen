@model GestorDeRestaurante.Dominio.Dtos.CrearUsuarioDto

@{
    ViewData["Title"] = "Agregar nuevo usuario";
}

<div class="container-fluid d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="col-11 col-sm-8 col-md-6 col-lg-5">
        <div class="saas-card shadow-lg" style="border-radius: 12px;">
            <div class="mb-4">
                <h3 style="font-weight: 700; font-size: 1.4rem; margin: 0;">Agregar usuario</h3>
            </div>

            <form asp-action="Crear" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 border-0 bg-danger bg-opacity-10 text-danger mb-3"
                     style="font-size: 0.85rem; border-left: 3px solid #ff4444 !important;">
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-dim" style="font-size: 0.8rem;">Identificación</label>
                        <input asp-for="Identificacion" class="form-control bg-dark text-white border-secondary" required />
                        <span asp-validation-for="Identificacion" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-dim" style="font-size: 0.8rem;">Nombre de usuario</label>
                        <input asp-for="NombreUsuario" class="form-control bg-dark text-white border-secondary" required />
                        <span asp-validation-for="NombreUsuario" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label text-dim" style="font-size: 0.8rem;">Nombre(s)</label>
                    <input asp-for="Nombre" class="form-control bg-dark text-white border-secondary" required />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label text-dim" style="font-size: 0.8rem;">Apellidos</label>
                    <input asp-for="Apellidos" class="form-control bg-dark text-white border-secondary" required />
                    <span asp-validation-for="Apellidos" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label text-dim" style="font-size: 0.8rem;">Correo electrónico</label>
                    <input asp-for="Email" type="email" class="form-control bg-dark text-white border-secondary" required />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label text-dim" style="font-size: 0.8rem;">Rol</label>
                    <select asp-for="Rol" class="form-select bg-dark text-white border-secondary" required>
                        <option value="" selected disabled>Seleccione un rol...</option>
                        <option value="Empleado">Empleado</option>
                        <option value="Cocina">Cocina</option>
                    </select>
                    <span asp-validation-for="Rol" class="text-danger small"></span>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn-saas py-2">Registrar usuario</button>
                    <a asp-controller="Usuarios" asp-action="Index" class="btn btn-outline-secondary text-dim" style="border-color: var(--border-color);">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}