@model GestorDeRestaurante.Dominio.Entidades.TableroCocina

@{
    ViewData["Title"] = "Tablero de Control de Cocina";
    
    var buscarNombre = ViewData["BuscarNombre"] as string;
    var filtrarPedido = ViewData["FiltrarPedido"] as int?;
    var filtrarTipo = ViewData["FiltrarTipo"] as string;
}

<style>
    .kanban-col { background-color: rgba(255,255,255,0.03); border-radius: 8px; min-height: 70vh; }
    .card-saas { background-color: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; }
    .text-dim { color: rgba(255,255,255,0.6); }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 style="font-weight: 700; font-size: 1.5rem; margin: 0;">Tablero de Control de Cocina</h2>
        <p class="text-dim">Módulo unificado para la gestión y preparación de órdenes en tiempo real.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn-saas text-decoration-none" style="display: inline-flex; align-items: center; gap: 8px;">
            <i class="bi bi-arrow-clockwise"></i> Sincronizar
        </a>
    </div>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="background-color: rgba(220,53,69,0.15); border-color: #dc3545; color: white;">
        <i class="bi bi-exclamation-circle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="background-color: rgba(40,167,69,0.15); border-color: #28a745; color: white;">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-4" style="background-color: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px;">
    <div class="card-body p-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            
            <div class="col-md-4">
                <label class="form-label text-dim small mb-1"><i class="bi bi-search"></i> Nombre del Platillo</label>
                <input type="text" name="buscarNombre" value="@buscarNombre" class="form-control form-control-sm bg-dark text-white border-secondary" placeholder="Ej: Hamburguesa...">
            </div>

            <div class="col-md-3">
                <label class="form-label text-dim small mb-1"><i class="bi bi-hash"></i> N° de Pedido</label>
                <input type="number" name="filtrarPedido" value="@filtrarPedido" class="form-control form-control-sm bg-dark text-white border-secondary" placeholder="Ej: 1024">
            </div>

            <div class="col-md-3">
                <label class="form-label text-dim small mb-1"><i class="bi bi-filter"></i> Tipo de Pedido</label>
                <select name="filtrarTipo" class="form-select form-select-sm bg-dark text-white border-secondary">
                    <option value="">-- Todos --</option>
                    <option value="Mesa" selected="@(filtrarTipo == "Mesa")">Mesa (En el sitio)</option>
                    <option value="ParaLlevar" selected="@(filtrarTipo == "ParaLlevar")">Para Llevar</option>
                    <option value="Express" selected="@(filtrarTipo == "Express")">Express (Domicilio)</option>
                </select>
            </div>

            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-info w-100 fw-bold text-white">
                    <i class="bi bi-funnel"></i> Filtrar
                </button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary w-100" title="Limpiar Filtros">
                    <i class="bi bi-eraser"></i> Limpiar
                </a>
            </div>

        </form>
    </div>
</div>
<div class="row g-3">
    <div class="col-md-4">
        <div class="p-3 kanban-col">
            <h5 class="text-warning mb-3"><i class="bi bi-list-task"></i> Pendientes (@Model.PlatillosPendientes.Count)</h5>
            @foreach (var item in Model.PlatillosPendientes)
            {
                <div class="card-saas p-3 mb-2">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h6 class="text-white mb-0">@item.NombreDelPlatillo</h6>
                            <small class="text-dim">Mesa @item.NumeroDeMesa | Pedido #@item.IdPedido</small>
                        </div>
                        <span class="badge bg-warning text-dark small fw-bold">x @(item.Cantidad)</span>
                    </div>

                    <div class="mb-2 pb-2 border-bottom border-secondary border-opacity-25">
                        <small class="text-dim d-block"><i class="bi bi-clock"></i> @item.FechaDeRegistro.ToString("dd/MM/yyyy HH:mm")</small>
                        <small class="text-dim d-block"><i class="bi bi-person"></i> @item.NombreDelCliente</small>
                        <small class="badge bg-secondary mt-1" style="font-size:0.7rem;">@item.TipoDePedido.ToString()</small>
                    </div>

                    @if (!string.IsNullOrEmpty(item.ObservacionDelPlatillo))
                    {
                        <p class="text-warning small bg-dark p-2 border-start border-warning border-2 rounded mb-2" style="font-size: 0.8rem;">
                            <i class="bi bi-chat-left-dots"></i> <strong>Notas Platillo:</strong> @item.ObservacionDelPlatillo
                        </p>
                    }

                    @if (!string.IsNullOrEmpty(item.ObservacionesPedido))
                    {
                        <p class="text-info small bg-dark p-2 border-start border-info border-2 rounded mb-2" style="font-size: 0.8rem;">
                            <i class="bi bi-info-circle"></i> <strong>Notas Pedido:</strong> @item.ObservacionesPedido
                        </p>
                    }

                    <button type="button" class="btn btn-sm btn-outline-warning w-100 fw-bold" onclick="abrirReceta(@item.Id)">
                        <i class="bi bi-play-fill"></i> Iniciar Preparación
                    </button>
                </div>
            }
        </div>
    </div>

    <div class="col-md-4">
        <div class="p-3 kanban-col">
            <h5 class="text-info mb-3"><i class="bi bi-clock-history"></i> En Preparación (@Model.PlatillosEnPreparacion.Count)</h5>
            @foreach (var item in Model.PlatillosEnPreparacion)
            {
                <div class="card-saas p-3 mb-2">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h6 class="text-white mb-0">@item.NombreDelPlatillo</h6>
                            <small class="text-dim">Mesa @item.NumeroDeMesa | Pedido #@item.IdPedido</small>
                        </div>
                        <span class="badge bg-info text-dark small fw-bold">x @(item.Cantidad)</span>
                    </div>

                    <div class="mb-2 pb-2 border-bottom border-secondary border-opacity-25">
                        <small class="text-dim d-block"><i class="bi bi-person"></i> @item.NombreDelCliente</small>
                        <small class="text-info d-block fw-bold" style="font-size:0.75rem;">
                            <i class="bi bi-hourglass-split"></i> Inicio: @item.FechaDeInicio.ToString("HH:mm") | Transcurrido: @((int)item.TiempoTranscurrido.TotalMinutes) min
                        </small>
                        <small class="badge bg-secondary mt-1" style="font-size:0.7rem;">@item.TipoDePedido.ToString()</small>
                    </div>

                    @if (!string.IsNullOrEmpty(item.Observaciones))
                    {
                        <p class="text-warning small bg-dark p-2 border-start border-warning border-2 rounded mb-2" style="font-size: 0.8rem;">
                            <i class="bi bi-chat-left-dots"></i> <strong>Notas Platillo:</strong> @item.Observaciones
                        </p>
                    }

                    @if (!string.IsNullOrEmpty(item.ObservacionesPedido))
                    {
                        <p class="text-info small bg-dark p-2 border-start border-info border-2 rounded mb-2" style="font-size: 0.8rem;">
                            <i class="bi bi-info-circle"></i> <strong>Notas Pedido:</strong> @item.ObservacionesPedido
                        </p>
                    }

                    <button type="button" class="btn btn-sm btn-outline-info w-100 fw-bold" onclick="abrirAtencion(@item.Id)">
                        <i class="bi bi-check-circle"></i> Despachar / Atendido
                    </button>
                </div>
            }
        </div>
    </div>

    <div class="col-md-4">
        <div class="p-3 kanban-col">
            <h5 class="text-success mb-3"><i class="bi bi-check-circle-fill"></i> Atendidos Hoy (@Model.PlatillosAtendidos.Count)</h5>
            @foreach (var item in Model.PlatillosAtendidos)
            {
                <div class="card-saas p-3 mb-2 opacity-75">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h6 class="text-white-50 text-decoration-line-through mb-0">@item.NombreDelPlatillo</h6>
                            <small class="text-dim">Pedido #@item.IdPedido</small>
                        </div>
                        <span class="badge bg-success small fw-bold">x @(item.Cantidad)</span>
                    </div>

                    <div class="mb-2 pb-2 border-bottom border-secondary border-opacity-25">
                        <small class="text-dim d-block"><i class="bi bi-person"></i> @item.NombreDelCliente</small>
                        <small class="text-dim d-block"><i class="bi bi-clock"></i> Despachado: @item.FechaDeAtencion.ToString("HH:mm")</small>
                        <small class="badge bg-secondary mt-1" style="font-size:0.7rem;">@item.TipoDePedido.ToString()</small>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="confirmarCocinaModal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary text-white">
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title" id="recetaPlatilloNombre">Receta del Platillo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="p-3 bg-secondary bg-opacity-10 border-bottom border-secondary small text-dim fw-bold">
                    INGREDIENTES NECESARIOS PARA LA PREPARACIÓN:
                </div>
                <div id="contenedorIngredientes" class="py-2">
                    </div>
            </div>
            <div class="modal-footer border-top border-secondary">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnConfirmarInicio" class="btn btn-sm btn-warning fw-bold text-dark">Confirmar e Iniciar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmarAtencionModal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary text-white">
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title"><i class="bi bi-check-circle-fill text-success"></i> Despachar Platillo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="small text-dim">¿Estás seguro de marcar este platillo como atendido? Pasará al historial de despacho.</p>
                <div class="mb-3">
                    <label for="obsAtencion" class="form-label text-dim small">Observaciones finales de entrega (Opcional)</label>
                    <textarea id="obsAtencion" class="form-control bg-dark text-white border-secondary" maxlength="200" style="font-size: 0.85rem; height: 80px;"></textarea>
                </div>
            </div>
            <div class="modal-footer border-top border-secondary">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnConfirmarAtencion" class="btn btn-sm btn-success fw-bold">Confirmar Atención</button>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@Html.AntiForgeryToken()
<script>
    async function abrirReceta(id) {
        const contenedorIngredientes = document.getElementById('contenedorIngredientes');
        contenedorIngredientes.innerHTML = '<div class="text-center py-3 text-dim"><div class="spinner-border spinner-border-sm" role="status"></div> Cargando ingredientes...</div>';

        try {
            const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
            const token = tokenElement ? tokenElement.value : '';

            const response = await fetch(`/Cocina/ObtenerDetallesReceta?idDetalle=${id}`, {
                method: 'GET',
                headers: { 
                    'RequestVerificationToken': token,
                    'Content-Type': 'application/json' 
                }
            });

            if (!response.ok) {
                throw new Error("No se pudo obtener la información de la receta.");
            }

            const text = await response.text();
            if (!text) throw new Error("La respuesta del servidor está vacía.");
            
            const data = JSON.parse(text);

            document.getElementById('recetaPlatilloNombre').innerText = `Preparar: ${data.nombrePlatillo}`;
            contenedorIngredientes.innerHTML = '';

            if (!data.ingredientes || data.ingredientes.length === 0) {
                contenedorIngredientes.innerHTML = `<div class="text-center py-3 text-muted small"><i class="bi bi-info-circle"></i> No hay ingredientes definidos.</div>`;
            } else {
                data.ingredientes.forEach((ing, index) => {
                    const lineBorder = index < data.ingredientes.length - 1 ? 'border-bottom border-secondary' : '';
                    const itemRow = `
                        <div class="d-flex px-3 py-2 ${lineBorder} text-white-50 small">
                            <div style="width: 60%; font-weight: 500;">${ing.nombre}</div>
                            <div style="width: 40%; text-align: right; font-family: monospace;" class="text-warning">${ing.cantidad} ${ing.unidadMedida}</div>
                        </div>`;
                    contenedorIngredientes.innerHTML += itemRow;
                });
            }

            document.getElementById('btnConfirmarInicio').onclick = function() {
                enviarFormulario('/TableroCocina/IniciarPreparacion', [{name: 'id', value: id}]);
            };

            new bootstrap.Modal(document.getElementById('confirmarCocinaModal')).show();

        } catch (error) {
            alert("Error: " + error.message);
        }
    }

    function enviarFormulario(url, campos) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = url + (window.location.search || '');

        campos.forEach(c => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = c.name;
            input.value = c.value;
            form.appendChild(input);
        });

        const token = document.querySelector('input[name="__RequestVerificationToken"]');
        if(token) form.appendChild(token.cloneNode(true));

        document.body.appendChild(form);
        form.submit();
    }

    function abrirAtencion(id) {
        document.getElementById('obsAtencion').value = '';
        const modal = new bootstrap.Modal(document.getElementById('confirmarAtencionModal'));

        document.getElementById('btnConfirmarAtencion').onclick = function() {
            const observacion = document.getElementById('obsAtencion').value;
            enviarFormulario('/TableroCocina/MarcarAtendido', [
                {name: 'id', value: id},
                {name: 'observacion', value: observacion}
            ]);
        };
        modal.show();
    }
</script>