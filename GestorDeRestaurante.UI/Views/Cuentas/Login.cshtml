@model GestorDeRestaurante.Dominio.Dtos.LoginDto

@{
    ViewData["Title"] = "Inicio de sesión";
}

<div class="container-fluid d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="col-11 col-sm-8 col-md-6 col-lg-4">
        <div class="saas-card shadow-lg" style="border-radius: 12px;">
            <div class="text-center mb-4">
                <div class="bg-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 40px; height: 40px;">
                    <i class="bi bi-lock-fill text-dark" style="font-size: 1.2rem;"></i>
                </div>
                <h3 style="font-weight: 700; font-size: 1.4rem; margin: 0;">Gestor de restaurante</h3>
                <p class="text-dim">Ingresa tus credenciales para continuar</p>
            </div>

            <form asp-action="Login" method="post">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2 border-0 bg-danger bg-opacity-10 text-danger" role="alert" style="font-size: 0.85rem; border-left: 3px solid #ff4444 !important;">
                        <i class="bi bi-exclamation-triangle me-2"></i> @ViewBag.Error
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label text-dim" style="font-size: 0.8rem;">Nombre de usuario</label>
                    <input asp-for="NombreUsuario" class="form-control bg-dark text-white border-secondary"
                           placeholder="Ej: Admin" style="color: white;" required />
                    <span asp-validation-for="NombreUsuario" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label text-dim" style="font-size: 0.8rem;">Contraseña</label>
                    <input asp-for="Contrasena" type="password" class="form-control bg-dark text-white border-secondary"
                           placeholder="••••••••" style="color: white;" required />
                    <span asp-validation-for="Contrasena" class="text-danger small"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn-saas w-100 py-2">Ingresar</button>
                </div>
            </form>

            <div class="mt-4 text-center text-dim" style="font-size: 0.75rem; opacity: 0.6;">
                Gestor de restaurante &copy; @DateTime.Now.Year
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}