@model List<GestorDeRestaurante.Dominio.Entidades.Receta>

@{
    ViewData["Title"] = "Gestión de Recetas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 style="font-weight: 700; font-size: 1.5rem; margin: 0;">Gestión de recetas</h2>
        <p class="text-dim">Módulo para administrar los ingredientes de los platillos del menú.</p>
    </div>
    <a asp-action="Crear" class="btn-saas text-decoration-none" style="display: inline-flex; align-items: center; gap: 8px;">
        <i class="bi bi-plus-circle"></i> Nueva receta
    </a>
</div>

<div class="mb-4">
    <form asp-action="Index" method="get" class="d-flex gap-2">
        <div class="position-relative flex-grow-1" style="max-width: 400px;">
            <i class="bi bi-search position-absolute" style="left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-secondary); font-size: 0.9rem;"></i>
            <input name="nombre" type="text" class="form-control bg-dark text-white border-secondary ps-5"
                   placeholder="Buscar por nombre del platillo..."
                   style="font-size: 0.85rem; height: 38px; --bs-secondary-color: var(--text-secondary); --bs-form-control-bg: var(--bg-card);" />
        </div>
        <button type="submit" class="btn-saas px-3 text-decoration-none"> Filtrar</button>
    </form>
</div>

<div class="saas-card p-0 overflow-hidden" style="padding: 0; border-radius: 8px;">

    <div class="d-flex align-items-center px-3 py-2 border-bottom flex-shrink-0"
         style="border-color: var(--border-color) !important; background-color: rgba(255,255,255,0.03); font-size: 0.7rem;
        color: var(--text-secondary); font-weight: 600;">
        <div style="width: 30%">Nombre de la receta</div>
        <div style="width: 35%">Nombre del platillo</div>
        <div style="width: 20%">Fecha de creación</div>
        <div style="width: 15%; text-align: right;">Acciones</div>
    </div>

    <div class="list-group list-group-flush">
        @foreach (var item in Model)
        {
            <div class="list-group-item bg-transparent border-secondary d-flex align-items-center px-3 py-3 flex-shrink-0"
                 style="border-color: var(--border-color) !important; cursor: default; font-size: 0.85rem; color: var(--text-primary)">

                <div style="width: 30%; font-weight: 500;">@item.Nombre</div>
                <div style="width: 35%">@item.Platillo.Nombre</div>
                <div style="width: 20%">@item.FechaDeCreacion.ToString("dd/MM/yyyy HH:mm")</div>
                <div class="flex-shrink-0" style="width: 15%; text-align: right;">
                    <a asp-action="Details" asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-info px-2 py-1"
                       style="font-size: 0.8rem; border-radius: 4px;">
                        <i class="bi bi-eye"></i> Ver Detalle
                    </a>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-dim" style="font-size: 0.85rem;">
                <i class="bi bi-journal-text d-block mb-2" style="font-size: 2rem; opacity: 0.5;"></i>
                No se encontraron recetas registradas en el sistema.
            </div>
        }
    </div>
</div>